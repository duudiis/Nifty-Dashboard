# ---- Web server ----
PORT=3000

# ---- Discord OAuth2 (https://discord.com/developers/applications) ----
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Must exactly match a redirect added in the Discord app, and point at /login
DISCORD_REDIRECT_URI=https://dashboard.example.com/login

# ---- Session signing ----
# Long random string. Rotating it logs everyone out.
DASHBOARD_JWT_SECRET=

# ---- Bot link ----
# Shared secret the bot(s) use to identify on the WebSocket hub.
# Must match DASHBOARD_TOKEN in each bot's .env.
DASHBOARD_TOKEN=

# ---- Search source ----
# Which provider powers search + browse. Internal for now (defaults to Deezer,
# which uses Deezer's public key-less API). Override only for testing.
# Options: deezer | youtube
#SEARCH_SOURCE=deezer
# NB: actual playback is the bot's job — to stream the deezer.com links the
# dashboard returns, the bot needs its LavaSrc Deezer source configured
# (DEEZER_MASTER_DECRYPTION_KEY + DEEZER_ARL).
